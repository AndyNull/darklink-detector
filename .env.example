# DarkLink Detector 环境变量配置
# 复制此文件为 .env 并按需修改
# cp .env.example .env

# 数据库连接 URL
# SQLite (默认): file:./db/custom.db
# MySQL:         mysql://user:password@localhost:3306/darklink_detector
# PostgreSQL:    postgresql://user:password@localhost:5432/darklink_detector
DATABASE_URL=file:./db/custom.db
