# 版本控制
.git
.gitignore

# 依赖（构建时重新安装）
node_modules
mini-services/*/node_modules

# 构建缓存
.next

# 运行时数据（通过 Volume 持久化）
db/*.db
db/*.db-journal
config/auth.json
config/sessions.json
config/database.json

# 开发文件
dev.log
*.log
upload
worklog.md
agent-ctx
.zscripts
.z-ai-config
.claude
.claude*

# Docker 文件自身
Dockerfile
docker-compose.yml

# 发布包（14MB，构建不需要）
*.tar.gz

# 开发备份和脚本
src/app_backup
scripts
examples
skills
download
snapshots

# IDE 和临时文件
.vscode
.idea
*.swp
*.swo
*~

# Shell 脚本（仅开发用）
*.sh
!docker-entrypoint.sh

# 环境文件（Docker 构建不使用本地 .env）
.env*
!.env.example
